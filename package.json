{
	"name": "swyxkit",
	"private": true,
	"version": "0.0.1",
	"scripts": {
		"dev": "vite dev",
		"start": "vite dev",
		"validate:yaml": "node scripts/validate-yaml.js",
		"prebuild": "npm run validate:yaml && svelte-kit sync",
		"build": "vite build",
		"preview": "wrangler dev",
		"preview:presence": "wrangler dev -c wrangler.toml -c wrangler.presence.toml",
		"deploy:presence": "wrangler deploy -c wrangler.presence.toml",
		"deploy:calibration": "wrangler deploy -c wrangler.calibration.toml",
		"deploy:monitor": "wrangler deploy -c wrangler.monitor.toml",
		"preview:monitor": "wrangler dev -c wrangler.monitor.toml --test-scheduled",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"podcast:migrate": "node scripts/migrate-podcast-feed.mjs",
		"podcast:test": "node --test scripts/podcast-feed.test.mjs",
		"podcast:validate": "node scripts/validate-podcast-feed.mjs",
		"podcast:upload": "node scripts/upload-podcast-r2.mjs",
		"test": "playwright test",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@playwright/test": "^1.37.0",
		"@svelte-put/toc": "^6.0.2",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.5.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/typography": "^0.5.9",
		"@types/node": "^25.9.1",
		"autoprefixer": "^10.4.14",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-svelte": "^2.36.0",
		"fast-xml-parser": "^5.8.0",
		"gray-matter": "^4.0.3",
		"postcss": "^8.4.27",
		"postcss-load-config": "^4.0.1",
		"prettier": "^3.2.0",
		"prettier-plugin-svelte": "^3.2.0",
		"prettier-plugin-tailwindcss": "^0.5.2",
		"slugify": "^1.6.6",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.3.3",
		"tslib": "^2.6.1",
		"typescript": "^5.4.0",
		"vite": "^6.0.0",
		"wrangler": "^4.113.0",
		"yaml": "^2.3.1"
	},
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"overrides": {
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"cookie": "^0.7.0"
	},
	"dependencies": {
		"@ethercorps/sveltekit-og": "^4.3.0",
		"@leeoniya/ufuzzy": "^1.0.8",
		"date-fns": "^2.30.0",
		"marked": "^12.0.0",
		"marked-gfm-heading-id": "^3.1.3",
		"shiki": "^1.6.0",
		"snarkdown": "^2.0.0",
		"svelte-action-balancer": "^1.0.4",
		"sveltekit-search-params": "^3.0.0"
	}
}
